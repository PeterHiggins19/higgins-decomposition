  "journal_standard": {
    "sections": [
      "1. Abstract (100-200 words)",
      "2. Data Source and Provenance (cite, hash, license)",
      "3. Carrier Definition and Justification",
      "4. Pipeline Configuration (version, constants, guards)",
      "5. Core Results (12-step output table)",
      "6. Extended Testing Results (universal + conditional)",
      "7. Transcendental Proximity Analysis",
      "8. Comparison to Legacy Result (cite EXP-XX)",
